# ── Server ──
PORT=8000
ENVIRONMENT=development

# ── Database ──
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lucosms?sslmode=disable

# ── Resend Email Provider ──
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Beta <beta@info.pitbox.fun>

# ── Auth ──
JWT_SECRET=change-this-to-a-secure-random-string

# ── Redis (optional; app falls back to Postgres if unavailable) ──
REDIS_ADDR=
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_DB=0

# ── Public backend URL used for emails, uploads, and payment callbacks ──
PUBLIC_URL=https://api.example.com
# PUBLIC_BASE_URL is also supported for backward compatibility.

# ── MarzPay ──
MARZPAY_BASE_URL=https://wallet.wearemarz.com/api/v1
# Accepts either the base64 token or username:password; the backend sends Basic auth.
MARZPAY_BASIC_AUTH=
